@page
@model HRRoll.Pages.Employees.CreateModel
@{
    ViewData["Title"] = "Create Employee";
}

<h1>Create Employee</h1>

<form method="post">
    <div class="form-group">
        <label asp-for="Employee.FullName" class="control-label"></label>
        <input asp-for="Employee.FullName" class="form-control" />
        <span asp-validation-for="Employee.FullName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Employee.Department" class="control-label"></label>
        <input asp-for="Employee.Department" class="form-control" />
        <span asp-validation-for="Employee.Department" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Employee.Salary" class="control-label"></label>
        <input asp-for="Employee.Salary" class="form-control" />
        <span asp-validation-for="Employee.Salary" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Employee.ClientMasterId" class="control-label">Client</label>
        <select asp-for="Employee.ClientMasterId" class="form-control" asp-items="Model.ClientMasterList">
            <option value="">-- Select Client --</option>
        </select>
        <span asp-validation-for="Employee.ClientMasterId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
