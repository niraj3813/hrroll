@page "{id:int}"
@model HRRoll.Pages.Clients.DetailsModel

@{
    ViewData["Title"] = "Client Details";
}

<h1>Client Details</h1>

<div>
    <h4>ClientMaster</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ClientMaster.MasterCode)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ClientMaster.MasterCode)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ClientMaster.ClientCode)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ClientMaster.ClientCode)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ClientMaster.ClientName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ClientMaster.ClientName)
        </dd>
    </dl>
</div>

<h4>Employees for @Model.ClientMaster.ClientCode</h4>

@if (Model.Employees != null && Model.Employees.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Last 4 of SSN</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model.Employees)
            {
                <tr>
                    <td>@emp.FullName</td>
                    <td>@emp.Email</td>
                    <td>@emp.Last4SSN</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No employees found for this client.</p>
}

<div class="mt-3">
    <a class="btn btn-primary" asp-page="./Edit" asp-route-id="@Model.ClientMaster.ClientMasterId">Edit</a>
    <a class="btn btn-secondary" asp-page="./Index">Back to List</a>
</div>
