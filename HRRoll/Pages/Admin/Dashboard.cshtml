@page
@model HRRoll.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1 class="mt-3">Admin Dashboard</h1>

<p class="lead">Welcome, @User.Identity?.Name!</p>

<div class="row mb-4">
    <div class="col-md-6 col-sm-12 mb-3">
        <div class="card text-white bg-primary shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Total Employees</h5>
                <p class="card-text display-6">@Model.EmployeeCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-sm-12 mb-3">
        <div class="card text-white bg-success shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Payroll Records</h5>
                <p class="card-text display-6">@Model.PayrollCount</p>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6 col-sm-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Manage Employees</h5>
                <a asp-page="/Employees/Index" class="btn btn-outline-primary">Go to Employees</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-sm-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Manage Payroll</h5>
                <a asp-page="/PayrollRecords/Index" class="btn btn-outline-success">Go to Payroll</a>
            </div>
        </div>
    </div>
</div>
